# Copy to .env or pass the same variables in Docker / shell.

# Required: remote URL (HTTPS with token is fine for private repos).
WAREHOUSE_GIT_URL=https://github.com/you/your-warehouse-repo.git

# Branch to track (default main).
WAREHOUSE_GIT_BRANCH=main

# Working clone path (inside the container this is often /data/repo).
WAREHOUSE_WORKDIR=warehouse-data/repo

# Manifest path inside the repository (default manifest/urls.csv).
WAREHOUSE_MANIFEST_PATH=manifest/urls.csv

# Staging directory for HTTP downloads before copying into the repo (mount this in Docker).
WAREHOUSE_DOWNLOAD_DIR=warehouse-data/downloads

# Git commit identity for automated commits.
WAREHOUSE_GIT_AUTHOR_NAME=warehouse-bot
WAREHOUSE_GIT_AUTHOR_EMAIL=warehouse-bot@example.com

# Dev only: skip TLS verification for HTTPS downloads.
# WAREHOUSE_HTTP_INSECURE_SKIP_VERIFY=true
